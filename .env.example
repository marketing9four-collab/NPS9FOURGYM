# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# Admin login (ver supabase/README.md para generar el hash)
# IMPORTANTE: Next.js expande variables "$algo" dentro de .env* — escapa cada
# "$" del hash bcrypt como "\$" o el valor quedará truncado/corrupto.
NPS_ADMIN_USER=Cami
NPS_ADMIN_PASSWORD_HASH=\$2a\$10\$replace-with-generated-bcrypt-hash

# Cookie de sesion firmada (ver supabase/README.md para generar)
SESSION_SECRET=replace-with-a-long-random-string

# Opcional: enlace "volver al sitio" en la pantalla de confirmacion
NEXT_PUBLIC_SITE_URL=
